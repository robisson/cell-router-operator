# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include module metadata and source directories.
!go.mod
!go.sum
!cmd/
!cmd/**
!cmd/**/*.go
!api/
!api/**
!api/**/*.go
!internal/
!internal/**
!internal/**/*.go

# Exclude tests from the runtime image build context.
**/*_test.go
